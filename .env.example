VLM_BASE_URL=https://api.example.com/v1
VLM_API_KEY=
VLM_MODEL=

# Greet uses its own vision model independently from Pilot.
GREET_VLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
GREET_VLM_API_KEY=
GREET_VLM_MODEL=qwen3-vl-plus

# Tencent Cloud account settings. Engine, voice, region, and codec remain in
# robonix_manifest.yaml under service.speech.config.
TENCENT_ASR_APPID=
TENCENTCLOUD_SECRET_ID=
TENCENTCLOUD_SECRET_KEY=

# Default ROS 2 middleware. Set both to rmw_fastrtps_cpp for a comparison run.
ROBONIX_RMW_IMPLEMENTATION=rmw_zenoh_cpp
RMW_IMPLEMENTATION=rmw_zenoh_cpp
